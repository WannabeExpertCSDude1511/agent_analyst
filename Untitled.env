# ── Mock vs Real mode ──────────────────────────────────────────────────────
# true  = fake tool outputs (no binaries needed, safe for any target)
# false = real tool execution on Kali (install tools first, see INSTALL.md)
TOOL_MOCK_MODE=true

# ── Ollama settings ────────────────────────────────────────────────────────
# The local Ollama server address (default is localhost)
OLLAMA_URL=http://localhost:11434
# Which model to use (must be pulled first: ollama pull llama3)
OLLAMA_MODEL=llama3.2:3b

# ── External community scripts ─────────────────────────────────────────────
# Where SecretFinder, LinkFinder etc are cloned
EXTERNAL_TOOLS_DIR=./external
